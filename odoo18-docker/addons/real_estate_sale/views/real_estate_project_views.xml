<odoo>
  <!-- Form view -->
  <record id="view_real_estate_project_form" model="ir.ui.view">
    <field name="name">real.estate.project.form</field>
    <field name="model">real.estate.project</field>
    <field name="arch" type="xml">
      <form>
        <sheet>
          <group>
            <field name="name"/>
            <field name="status"/>
            <field name="analytic_account_id"/>
          </group>
          <group>
            <field name="description"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <!-- List view -->
  <record id="view_real_estate_project_tree" model="ir.ui.view">
    <field name="name">real.estate.project.tree</field>
    <field name="model">real.estate.project</field>
    <field name="arch" type="xml">
      <list>
        <field name="name"/>
        <field name="analytic_account_id"/>
        <field name="status"/>
      </list>
    </field>
  </record>

  <!-- Action -->
  <record id="action_real_estate_project" model="ir.actions.act_window">
    <field name="name">Projets immobiliers</field>
    <field name="res_model">real.estate.project</field>
    <field name="view_mode">list,form</field>
  </record>

  <!-- Menu -->
  <menuitem id="menu_real_estate_root"
            name="Immobilier"
            sequence="50"/>
  <menuitem id="menu_real_estate_project"
            name="Projets"
            parent="menu_real_estate_root"
            action="action_real_estate_project"/>
</odoo>