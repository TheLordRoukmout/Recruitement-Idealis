<odoo>
  <template id="shop_project_step" name="Shop - Choix du projet immobilier">
    <t t-call="website.layout">
      <div class="container mt-5 mb-5">
        <div class="row justify-content-center">
          <div class="col-lg-8">

            <h2 class="mb-4">Choisissez un projet immobilier</h2>

            <!-- Warning si projet terminé -->
            <t t-if="selected_project and selected_project.status == 'done'">
              <div class="alert alert-warning" role="alert">
                <i class="fa fa-exclamation-triangle"/>
                Le projet sélectionné est <strong>terminé</strong>.
                Vous pouvez continuer, mais vérifiez la pertinence de votre commande.
              </div>
            </t>

            <form method="post" action="/shop/project">
              <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

              <div class="row g-3 mb-4">
                <!-- Option : aucun projet -->
                <div class="col-12">
                  <div class="form-check">
                    <input class="form-check-input" type="radio"
                           name="project_id" id="project_none" value="0"
                           t-att-checked="not selected_project and 'checked' or None"/>
                    <label class="form-check-label" for="project_none">
                      Aucun projet
                    </label>
                  </div>
                </div>

                <!-- Liste des projets -->
                <t t-foreach="projects" t-as="project">
                  <div class="col-12">
                    <div t-attf-class="card #{selected_project and selected_project.id == project.id and 'border-primary' or ''}">
                      <div class="card-body d-flex align-items-center gap-3">
                        <input class="form-check-input mt-0" type="radio"
                          name="project_id"
                          t-att-id="'project_%d' % project.id"
                          t-att-value="project.id"
                          t-att-data-status="project.status"
                          t-att-checked="selected_project and selected_project.id == project.id and 'checked' or None"/>
                        <label t-att-for="'project_%d' % project.id" class="w-100" style="cursor:pointer">
                          <div class="d-flex justify-content-between align-items-center">
                            <strong t-esc="project.name"/>
                            <span t-attf-class="badge #{project.status == 'done' and 'bg-secondary' or project.status == 'in_progress' and 'bg-success' or 'bg-primary'}">
                              <t t-if="project.status == 'planned'">Planifié</t>
                              <t t-elif="project.status == 'in_progress'">En cours</t>
                              <t t-else="">Terminé</t>
                            </span>
                          </div>
                          <small t-if="project.description" class="text-muted" t-esc="project.description"/>
                        </label>
                      </div>
                    </div>
                  </div>
                </t>
              </div>

              <div class="d-flex justify-content-between">
                <a href="/shop/cart" class="btn btn-outline-secondary">
                  <i class="fa fa-arrow-left"/> Retour au panier
                </a>
                <button type="submit" class="btn btn-primary">
                  Continuer <i class="fa fa-arrow-right"/>
                </button>
              </div>

            </form>
          </div>
        </div>
      </div>
    </t>
  </template>
</odoo>