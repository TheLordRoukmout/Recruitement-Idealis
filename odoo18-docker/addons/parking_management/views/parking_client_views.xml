<odoo>
  <record id="view_parking_client_form" model="ir.ui.view">
    <field name="name">parking.client.form</field>
    <field name="model">parking.client</field>
    <field name="arch" type="xml">
      <form>
        <sheet>
          <group>
            <field name="first_name"/>
            <field name="last_name"/>
            <field name="license_plate"/>
            <field name="subscription_paid"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <record id="view_parking_client_list" model="ir.ui.view">
    <field name="name">parking.client.list</field>
    <field name="model">parking.client</field>
    <field name="arch" type="xml">
      <list>
        <field name="first_name"/>
        <field name="last_name"/>
        <field name="license_plate"/>
        <field name="subscription_paid"/>
      </list>
    </field>
  </record>

  <record id="action_parking_client" model="ir.actions.act_window">
    <field name="name">Clients</field>
    <field name="res_model">parking.client</field>
    <field name="view_mode">list,form</field>
  </record>

  <menuitem id="menu_parking_root"
            name="Parking"
            sequence="60"/>
  <menuitem id="menu_parking_client"
            name="Clients"
            parent="menu_parking_root"
            action="action_parking_client"/>
</odoo>