<odoo>
  <record id="view_parking_place_form" model="ir.ui.view">
    <field name="name">parking.place.form</field>
    <field name="model">parking.place</field>
    <field name="arch" type="xml">
      <form>
        <sheet>
          <group>
            <field name="name"/>
            <field name="is_available"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <record id="view_parking_place_list" model="ir.ui.view">
    <field name="name">parking.place.list</field>
    <field name="model">parking.place</field>
    <field name="arch" type="xml">
      <list>
        <field name="name"/>
        <field name="is_available"/>
      </list>
    </field>
  </record>

  <record id="action_parking_place" model="ir.actions.act_window">
    <field name="name">Places</field>
    <field name="res_model">parking.place</field>
    <field name="view_mode">list,form</field>
  </record>

  <menuitem id="menu_parking_place"
            name="Places"
            parent="menu_parking_root"
            action="action_parking_place"/>
</odoo>